class Solution {
public:
    int mostWordsFound(vector<string>& sentences) {
        int ans=0;

        for(string sentence: sentences){
            int spaces=0;
            for(char ch: sentence){
                if(ch==' '){
                    spaces++;

                }
               

            }
             ans=max(ans, spaces+1);
        }
         return ans;
    }
};
